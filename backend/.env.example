# /home/obed/Documents/free-webinar-sales/backend/.env.example
# Copy to .env and fill in real values.

ENVIRONMENT=development

# --- CORS: the frontend origin(s), comma-separated ---
# Vercel production frontend:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://july-webinar-2026.vercel.app

# --- PostgreSQL / Supabase ---
# Local Postgres:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/webinar_funnel
# Supabase (Render/production):
# DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/webinar_funnel

# --- GoHighLevel ---
# Private Integration Token (PIT) only — Settings > Private Integrations in GHL.
# Legacy V1 "Location API keys" are deprecated (end-of-support Dec 31, 2025).
GHL_API_KEY=
# Your GHL sub-account (Location) id — required for contact upsert.
GHL_LOCATION_ID=
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
# Optional: paste an Inbound Webhook trigger URL from a GHL Workflow.
# This is separate from the direct contact upsert and is not a replacement for it.
GHL_WEBHOOK_URL=
# Optional: GHL calendar ID from Calendars > [calendar] > Settings > embed code.
# Used to build the "Add to Calendar" booking widget on the thank-you page.
GHL_CALENDAR_ID=

# --- Zoom ---
ZOOM_REGISTRATION_URL=https://us06web.zoom.us/meeting/register/kZIx9YQbSBi-GbYHGHCBrg
