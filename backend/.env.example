# /home/obed/Documents/free-webinar-sales/backend/.env.example
# Copy to .env and fill in real values.

ENVIRONMENT=development

# --- CORS: the frontend origin(s), comma-separated ---
# Vercel production frontend:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://july-webinar-2026.vercel.app

# --- PostgreSQL / Supabase ---
# Local Postgres:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/webinar_funnel
# Supabase direct connection (used by this FastAPI app):
# DATABASE_URL=postgresql+asyncpg://postgres:<your-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:XtrA4g5t7y8u4defgddghfggggggkfg@db.nuhsuiafksnlrilzgguw.supabase.co:5432/postgres?sslmode=require

# --- GoHighLevel ---
# Private Integration Token (PIT) only — Settings > Private Integrations in GHL.
# Legacy V1 "Location API keys" are deprecated (end-of-support Dec 31, 2025).
GHL_API_KEY=
# Your GHL sub-account (Location) id — required for contact upsert.
GHL_LOCATION_ID=
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
# Optional: paste an Inbound Webhook trigger URL from a GHL Workflow.
# This is separate from the direct contact upsert and is not a replacement for it.
GHL_WEBHOOK_URL=
# Optional: GHL calendar ID from Calendars > [calendar] > Settings > embed code.
# Used to build the "Add to Calendar" booking widget on the thank-you page.
GHL_CALENDAR_ID=

# --- Zoom ---
ZOOM_REGISTRATION_URL=https://us06web.zoom.us/meeting/register/kZIx9YQbSBi-GbYHGHCBrg
# Pabbly Connect webhook URL for the workflow that handles Zoom registration + confirmation email.
# Use the Webhook trigger from the Pabbly Connect workflow (App Event: "Catch Webhook (Preferred)").
# If that event type changes in Pabbly, copy the new URL here and in Render.
PABBLY_WEBHOOK_URL=


// Resolved

GHL_LOCATION_ID=Qum6zwDsfvHsbXiehFQR

# --- Google Sheets (optional) ---
# Base64-encoded Google service account JSON key. Encode the entire
# service account JSON and set it here (do NOT commit real credentials).
GOOGLE_SHEETS_CREDENTIALS_B64=
# Target Google Sheet ID (the long ID from the sheet URL).
# Ensure the service account's client_email from the JSON is granted
# Editor access to the sheet, otherwise writes will fail with a
# permissions error even if the credentials are valid.
GOOGLE_SHEET_ID=