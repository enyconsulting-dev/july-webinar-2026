# /home/obed/Documents/free-webinar-sales/frontend/.env.example
# Copy to .env (or .env.local) for local dev. All vars are PUBLIC (baked into
# the bundle) — never put secrets here.


# --- Frontend hosting variables (Vercel, Netlify, etc.) ---

# Backend API base. Leave blank in dev to use the Vite proxy (/api -> :8000).
# In production this should point at your Render backend URL.
VITE_API_BASE=https://july-webinar-2026.onrender.com

# Zoom registration link registrants are routed to.
VITE_ZOOM_URL=https://us06web.zoom.us/meeting/register/kZIx9YQbSBi-GbYHGHCBrg

# Hosted checkout links keyed by region.
VITE_VIP_CHECKOUT_URL_NGN=
VITE_VIP_CHECKOUT_URL_USD=
VITE_PLATINUM_CHECKOUT_URL_NGN=
VITE_PLATINUM_CHECKOUT_URL_USD=

# Optional: real event start time (ISO 8601) to drive the countdown.
# Example: 2026-07-20T18:00:00-04:00
VITE_EVENT_STARTS_AT=

# Optional: Pabbly webhook URL metadata for frontend docs only; keep in sync with the backend setting.
VITE_PABBLY_WEBHOOK_URL=

# Supabase public key (publishable key) for browser-side use.
VITE_SUPABASE_ANON_KEY=sb_publishable_PMnHMjUc9CQO9ghDsyYNcA_0BPV1_1M

